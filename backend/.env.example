# Backend Production Environment (MongoDB Atlas için)
# .env.production olarak kopyala ve değerleri değiştir

MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/dbline?retryWrites=true&amp;w=majority
JWT_SECRET=your-super-secret-jwt-key-change-this
NODE_ENV=production
PORT=5000

# İYİ Fatura
EDM_USERNAME=your-edm-username
EDM_PASSWORD=your-edm-password
NES_USERNAME=your-nes-username
NES_PASSWORD=your-nes-password

# İyzico
IYZIPAY_API_KEY=
IYZIPAY_SECRET_KEY=

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=app-password

# Diğer
FRONTEND_URL=https://dbline.com.tr
CLOUDINARY_URL= (opsiyonel)

